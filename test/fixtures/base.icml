					<Row Self="ue1i186Row3" Name="3" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" SingleRowHeight="41.923228346456696" MinimumHeight="41.923228346456696" AutoGrow="true" />
					<Row Self="ue1i186Row4" Name="4" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" SingleRowHeight="33.349124698261036" MinimumHeight="33.349124698261036" AutoGrow="true" />
					<Row Self="ue1i186Row5" Name="5" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" SingleRowHeight="40.923228346456696" MinimumHeight="40.923228346456696" AutoGrow="true" />
					<Column Self="ue1i186Column0" Name="0" TextTopInset="2.834645669291339" TextLeftInset="2.834645669291339" TextBottomInset="2.834645669291339" TextRightInset="4" ClipContentToTextCell="true" SingleColumnWidth="51.023622047244146" />
					<Column Self="ue1i186Column1" Name="1" TextTopInset="5.669291338582678" TextLeftInset="0" TextBottomInset="8.503937007874017" TextRightInset="2.834645669291339" ClipContentToTextCell="true" SingleColumnWidth="266.4566929133858" />
					<Cell Self="ue1i186ia" Name="0:0" RowSpan="1" ColumnSpan="2" CellType="TextTypeCell" TextTopInset="2.834645669291339" TextLeftInset="2.834645669291339" TextBottomInset="2.834645669291339" TextRightInset="4" ClipContentToTextCell="true" AppliedCellStyle="CellStyle/cel-corpo" AppliedCellStylePriority="1" TopInset="2.834645669291339" RightInset="4" BottomInset="2.834645669291339" RotationAngle="0" LeftEdgeStrokePriority="25" RightEdgeStrokePriority="1" TopEdgeStrokePriority="25" BottomEdgeStrokePriority="25">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-cabecalho - cópia">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-10">
								<Content>Aposentadoria (pessoa com deficiência, que engloba pessoas com TEA)</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i0" Name="0:1" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" AppliedCellStyle="CellStyle/cel-corpo-esq" AppliedCellStylePriority="3" LeftInset="4" TopInset="4" RightInset="4" BottomInset="4" RotationAngle="0" ClipContentToCell="false" LeftEdgeStrokePriority="27" RightEdgeStrokePriority="28" TopEdgeStrokePriority="27" BottomEdgeStrokePriority="41">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-10">
								<Content>Natureza do benefício</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i1" Name="1:1" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="5.669291338582678" TextLeftInset="0" TextBottomInset="8.503937007874017" TextRightInset="2.834645669291339" ClipContentToTextCell="true" AppliedCellStyle="CellStyle/cel-corpo" AppliedCellStylePriority="4" LeftInset="0" RightInset="2.834645669291339" LeftEdgeStrokePriority="28" RightEdgeStrokePriority="28" TopEdgeStrokePriority="28" BottomEdgeStrokePriority="94">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-fio-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Properties>
									<Leading type="unit">9.5</Leading>
								</Properties>
								<Content>Aposentadoria diferenciada no RGPS, com regras distintas de tempo de contribuição e/ou idade, conforme o grau de deficiência (leve, moderado ou grave).</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i2" Name="0:2" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" AppliedCellStyle="CellStyle/cel-corpo-esq" AppliedCellStylePriority="3" LeftInset="4" TopInset="4" RightInset="4" BottomInset="4" RotationAngle="0" ClipContentToCell="false" LeftEdgeStrokePriority="27" RightEdgeStrokePriority="28" TopEdgeStrokePriority="41" BottomEdgeStrokePriority="54">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Content>Requisitos</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i3" Name="1:2" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="5.669291338582678" TextLeftInset="0" TextBottomInset="8.503937007874017" TextRightInset="2.834645669291339" ClipContentToTextCell="true" AppliedCellStyle="CellStyle/cel-corpo" AppliedCellStylePriority="4" LeftInset="0" RightInset="2.834645669291339" LeftEdgeStrokePriority="28" RightEdgeStrokePriority="28" TopEdgeStrokePriority="94" BottomEdgeStrokePriority="58">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-fio-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Properties>
									<Leading type="unit">9.5</Leading>
								</Properties>
								<Content>Por tempo de contribuição:</Content>
								<Br />
							</CharacterStyleRange>
						</ParagraphStyleRange>
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-fio-rosa - cópia">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Properties>
									<Leading type="unit">9.5</Leading>
								</Properties>
								<Content>- em caso de deficiência grave, 25 anos de contribuição para homens e 20 anos de contribuição para mulheres;</Content>
								<Br />
								<Content>- em caso de deficiência moderada, 29 anos de contribuição para homens e 24 anos de contribuição para mulheres;</Content>
								<Br />
								<Content>- em caso de deficiência leve, 33 anos de contribuição para homens e 28 anos de contribuição para mulheres.</Content>
								<Br />
							</CharacterStyleRange>
						</ParagraphStyleRange>
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-fio-rosa - cópia" MinimumWordSpacing="69">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-47">
								<Properties>
									<Leading type="unit">9.5</Leading>
								</Properties>
								<Content>Por idade (comprovada a contribuição por pelo menos 15 anos e a deficiência por pelo menos 15 anos): 60 anos para homens e 55 anos para mulheres.</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i4" Name="0:3" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" AppliedCellStyle="CellStyle/cel-corpo-esq" AppliedCellStylePriority="3" LeftInset="4" TopInset="4" RightInset="4" BottomInset="4" RotationAngle="0" ClipContentToCell="false" LeftEdgeStrokePriority="27" RightEdgeStrokePriority="28" TopEdgeStrokePriority="54" BottomEdgeStrokePriority="67">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Content>Cálculo do benefício</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i5" Name="1:3" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="5.669291338582678" TextLeftInset="0" TextBottomInset="8.503937007874017" TextRightInset="2.834645669291339" ClipContentToTextCell="true" AppliedCellStyle="CellStyle/cel-corpo" AppliedCellStylePriority="4" LeftInset="0" RightInset="2.834645669291339" LeftEdgeStrokePriority="28" RightEdgeStrokePriority="28" TopEdgeStrokePriority="58" BottomEdgeStrokePriority="71">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-fio-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Properties>
									<Leading type="unit">9.5</Leading>
								</Properties>
								<Content>Por tempo de contribuição: 100% do salário de benefício.</Content>
								<Br />
							</CharacterStyleRange>
						</ParagraphStyleRange>
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-fio-rosa - cópia" MinimumWordSpacing="77">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-24">
								<Properties>
									<Leading type="unit">9.5</Leading>
								</Properties>
								<Content>Por idade: 70% do salário de benefício + 1% por cada 12 contribuições, até 30%. Acréscimo de 25% se necessitar de assistência permanente.</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i6" Name="0:4" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" AppliedCellStyle="CellStyle/cel-corpo-esq" AppliedCellStylePriority="3" LeftInset="4" TopInset="4" RightInset="4" BottomInset="4" RotationAngle="0" ClipContentToCell="false" LeftEdgeStrokePriority="27" RightEdgeStrokePriority="28" TopEdgeStrokePriority="67" BottomEdgeStrokePriority="80">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Content>Revisões</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i7" Name="1:4" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="5.669291338582678" TextLeftInset="0" TextBottomInset="8.503937007874017" TextRightInset="2.834645669291339" ClipContentToTextCell="true" AppliedCellStyle="CellStyle/cel-corpo" AppliedCellStylePriority="4" LeftInset="0" RightInset="2.834645669291339" LeftEdgeStrokePriority="28" RightEdgeStrokePriority="28" TopEdgeStrokePriority="71" BottomEdgeStrokePriority="84">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-fio-rosa" MinimumWordSpacing="76">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-28">
								<Properties>
									<Leading type="unit">9.5</Leading>
								</Properties>
								<Content>Definitiva após concessão, salvo revisão administrativa em caso de mudança significativa do grau de deficiência ou comprovação de fraude.</Content>
							</CharacterStyleRange>
						</ParagraphStyleRange>
					</Cell>
					<Cell Self="ue1i186i8" Name="0:5" RowSpan="1" ColumnSpan="1" CellType="TextTypeCell" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" AppliedCellStyle="CellStyle/cel-corpo-esq" AppliedCellStylePriority="3" LeftInset="4" TopInset="4" RightInset="4" BottomInset="4" RotationAngle="0" ClipContentToCell="false" LeftEdgeStrokePriority="27" RightEdgeStrokePriority="28" TopEdgeStrokePriority="80" BottomEdgeStrokePriority="27">
						<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/tabela%3atabela-corpo-rosa">
							<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
								<Content>E</Content>
							</CharacterStyleRange>
