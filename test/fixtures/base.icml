				<Content>Novo parágrafo</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo" SpaceBefore="1.4173228346456694">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14</Leading>
				</Properties>
				<Content>No caso do dependente que seja </Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/bold">
				<Properties>
					<Leading type="unit">14</Leading>
				</Properties>
				<Content>diagnosticado</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14</Leading>
				</Properties>
				<Content> com TEA, a lei prevê a possibilidade de recebimento da pensão por morte, inclusive após os 21 anos de idade, desde que reconhecida a deficiência.</Content>
				<Note Collapsed="false" CreationDate="2026-07-04T00:57:41" ModificationDate="2026-07-04T00:57:44" UserName="Luiz" AppliedDocumentUser="dDocumentUser0">
					<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/$ID/[No paragraph style]">
						<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
							<Properties>
								<AppliedFont type="string">Inter 18pt</AppliedFont>
							</Properties>
							<Content>Nota de teste</Content>
						</CharacterStyleRange>
					</ParagraphStyleRange>
				</Note>
				<Br />
				<Content>De acordo com o art. 16 da Lei nº 8.213/1991, que dispõe sobre os Planos de Benefícios da Previdência Social, são considerados dependentes do segurado:</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo-recuo-bullet">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">13.3</Leading>
				</Properties>
				<Content>cônjuge, companheira, companheiro e filho não emancipado, de qualquer condição, menor de 21 anos, ou inválido, ou que tenha deficiência intelectual, mental ou deficiência grave;</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo-recuo-bullet" SpaceBefore="2.598425196850394">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">13.3</Leading>
				</Properties>
				<Content>irmão não emancipado, de qualquer condição, menor de </Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" AppliedConditions="Condition/isoladas">
				<Properties>
					<Leading type="unit">13.3</Leading>
				</Properties>
				<Content>21</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">13.3</Leading>
				</Properties>
				<Content> anos, ou inválido, ou que tenha deficiência intelectual, mental ou deficiência grave;</Content>
				<Br />
				<Content>pais.</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">13.5</Leading>
				</Properties>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo" SpaceBefore="3.248031496062992">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.397141607876142</Leading>
				</Properties>
				<Content>Recentemente, a Lei nº 15.108/2025 alterou a lei que rege os benefícios previdenciários para estabelecer que enteado, menor sob tutela </Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.9895</Leading>
				</Properties>
				<Content>e menor sob guarda judicial são equiparados a filhos, desde que haja </Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.870038741888113</Leading>
				</Properties>
				<Content>declaração do segurado e que não tenham condições de prover o próprio sustento e educação.</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.870038741888113</Leading>
				</Properties>
				<Content>Dessa forma, esses dependentes, se tiverem TEA, poderão igualmente ser reconhecidos como beneficiários da pensão por morte.</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo" SpaceBefore="3.248031496062992">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.397141607876142</Leading>
				</Properties>
				<Content>Os valores recebidos a título de pensão, pecúlio, montepio</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/sobrescrito">
				<Properties>
					<Leading type="unit">14.397141607876142</Leading>
				</Properties>
				<Footnote>
					<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3anota-rodape">
						<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
							<Content><?ACE 4?>	Sistema de contribuição criado para garantir pensão ou benefício a familiares de um trabalhador ou associado após sua morte.</Content>
						</CharacterStyleRange>
					</ParagraphStyleRange>
				</Footnote>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.397141607876142</Leading>
				</Properties>
				<Content> e auxílio pagos pelo regime de Previdência Social ou por entidades de previ</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Content>dência privada a pessoas com deficiência mental são </Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/destaque-sublinhado">
				<Content>isentos de IRPF</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Content> com base na Lei nº 8.687/1993. Essa isenção não alcança outros rendimentos ou rendimentos pagos por outras fontes que tenham a mesma denominação.</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo" SpaceBefore="1.9488188976377954">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.620902889933411</Leading>
				</Properties>
				<Content>O livro acompanha a trajetória das pessoas com TEA desde o diagnóstico até a vida adulta, abordando o funcionamento do SUS e dos planos de saúde, além de diretrizes para uma educação inclusiva, com destaque para o atendimento educacional especializado, o uso de tecnologias assistivas e o enfrentamento ao estigma e ao </Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/italic">
				<Properties>
					<Leading type="unit">14.620902889933411</Leading>
				</Properties>
				<Content>bullying</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.620902889933411</Leading>
				</Properties>
				<Content> no ambiente escolar. Também contempla aspectos da seguridade social, com orientações sobre acesso ao BPC-Loas, modalidades de aposentadoria e direitos previdenciários.</Content>
			</CharacterStyleRange>
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Properties>
					<Leading type="unit">14.870038741888113</Leading>
				</Properties>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3acorpo" MinimumWordSpacing="83">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-6">
				<Properties>
					<Leading type="unit">14.870038741888113</Leading>
				</Properties>
				<Content>Para a concessão, é necessário apresentar laudos médicos que atestem a deficiência, além da documentação que comprove o vínculo de dependência. O valor do benefício é calculado com base na aposentadoria que o segurado recebia ou teria direito se estivesse aposentado por incapacidade permanente na data do óbito.</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3adestaque 1 miolo esp ant" MinimumWordSpacing="83">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-7">
				<Content>A dependência econômica dos filhos (inclusive enteados, menores sob tutela ou guarda) é presumida, mas, nos casos de maiores de 21 anos de idade com deficiência, o INSS exige comprovação médica da condição para manutenção do benefício.</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3adestaque 1 miolo esp ant" MinimumWordSpacing="82">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" Tracking="-9">
				<Content>A pensão por morte não exige período mínimo de contribuição (carência), mas é necessário que o segurado esteja inscrito e em dia com a Previdência Social no momento do falecimento, salvo hipóteses legais de manutenção da qualidade de segurado.</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3adestaque 1 miolo">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Content>A pensão pode ser acumulada com outros benefícios previdenciários, mas existem regras de limitação de valores a partir da Reforma da Previdência (EC nº 103/2019).</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3afig-tab-titulo-arte" SpaceAfter="5.669291338582678">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Content>Resumo: benefícios previdenciários para pessoas com TEA</Content>
				<Br />
			</CharacterStyleRange>
		</ParagraphStyleRange>
		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/miolo%3aobjeto">
			<CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
				<Table Self="ue1i186" HeaderRowCount="1" FooterRowCount="0" TextTopInset="4" TextLeftInset="4" TextBottomInset="4" TextRightInset="4" ClipContentToTextCell="false" BodyRowCount="5" ColumnCount="2" AppliedTableStyle="TableStyle/tabela2" TableDirection="LeftToRightDirection">
					<Row Self="ue1i186Row0" Name="0" TextTopInset="2.834645669291339" TextLeftInset="2.834645669291339" TextBottomInset="2.834645669291339" TextRightInset="4" ClipContentToTextCell="true" SingleRowHeight="18.613816148725164" MinimumHeight="18.613816148725164" AutoGrow="true" />
